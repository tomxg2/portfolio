# ─── Backend API URL ──────────────────────────────────────────────────────────
# Your Railway backend URL — no trailing slash
# In development this defaults to http://localhost:3001
VITE_API_URL=https://your-portfolio-backend.up.railway.app

# ─── Supabase Realtime (multiplayer cursors) ──────────────────────────────────
# Both come from your Supabase dashboard → Project Settings → API.
# Anon key is safe to expose to the browser.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
