# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key (NOT the anon key) — keep this secret
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ─── Resend ───────────────────────────────────────────────────────────────────
# API key from resend.com dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address where contact form notifications will be sent (your email)
CONTACT_EMAIL=tom@yourdomain.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL — no trailing slash
FRONTEND_URL=https://your-portfolio.vercel.app
